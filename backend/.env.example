# ==============================
# Finance Dashboard Backend .env.example
# ==============================

# Required: Yes
# Neon production database URL
DATABASE_URL=postgresql://app_user:replace-password@ep-example-123456.us-east-1.aws.neon.tech/finance_dashboard?sslmode=require

# Required: Yes (for tests)
# Neon test database URL
TEST_DATABASE_URL=postgresql://app_user:replace-password@ep-example-123456.us-east-1.aws.neon.tech/finance_dashboard_test?sslmode=require

# Required: Yes
# Firebase project identifier used for JWT verification
FIREBASE_PROJECT_ID=finance-dashboard

# Required: Yes
# Comma-separated CORS allowlist
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# Required: Yes
ENVIRONMENT=development

# Required: Yes
LOG_LEVEL=DEBUG

# Optional: defaults shown
LOG_DIR=./logs
PORT=8000
FIREBASE_KEYS_TTL_SECONDS=3600
MIN_DB_CONNECTIONS=1
MAX_DB_CONNECTIONS=10

# Optional: comma-separated emails that should auto-sync as analyst role.
# Any email not listed here remains viewer by default.
ANALYST_EMAILS=analyst@test.com
