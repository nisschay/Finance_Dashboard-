# ==================================
# Finance Dashboard Frontend .env.example
# ==================================

# Required: Yes
# Firebase SDK config values from Firebase Console
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyReplaceWithYourKey
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=finance-dashboard.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=finance-dashboard
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=finance-dashboard.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abcdef123456

# Required: Yes
# Local development API base URL (production should use your hf.space URL)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
